import { navItems, profile } from './data';

export default function Footer({ onNavigate }: { onNavigate: (href: string) => void }) {
  return (
    <footer className="border-t border-ink-200/60 bg-ink-100/50">
      <div className="container-wide py-10">
        <div className="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-center">
          <div>
            <p className="font-serif text-lg font-medium text-ink-900">
              {profile.name}
            </p>
            <p className="mt-1 text-sm text-ink-500">
              {profile.major} · {profile.school}
            </p>
          </div>
          <nav className="flex flex-wrap gap-x-5 gap-y-2">
            {navItems.map((item) => (
              <button
                key={item.id}
                onClick={() => onNavigate(item.href)}
                className="link-underline text-sm text-ink-600 hover:text-ink-900"
              >
                {item.label}
              </button>
            ))}
          </nav>
        </div>
        <div className="mt-8 border-t border-ink-200/60 pt-6 text-xs text-ink-400">
          © {new Date().getFullYear()} {profile.name} · Hồ sơ học tập cá nhân
        </div>
      </div>
    </footer>
  );
}
